# Keep the image to the source, the deposited prediction bundles, and the analysis env.
.git
.venv
**/__pycache__
**/*.pyc
*.egg-info
reproduced_results.csv
out/
# raw single-cell data is never shipped (data/ holds only download scripts + manifests)
data/**/*.h5ad
data/**/*.h5
data/**/*.loom
data/**/*.zarr
# build/ holds the conda-pack tarballs for the heavy training image; keep it out of the small EVAL
# image context, but the negation lets Containerfile.train COPY the packed envs it needs.
build/**
!build/train_envs/**

# ---- raw data & large scientific binaries (downloaded via scripts/, never committed) ----
data/**
!data/README.md
outputs/
*.h5ad
*.h5
*.loom
*.npz
*.npy
# ...but keep the small deposited paper-backing arrays under results/_paper/
!results/_paper/*.npz
# ...and the 4 example format-demo bundles (they document the .npz layout; excluded from the census re-score)
!predictions/example/*.npz
# ...and the deposited compact per-stratum MEAN bundles (Pearson-Δ-exact, ~KB each) that back the
# 35-cell census, so `make reproduce-eval` recomputes the real per-(model,task) scores GPU-free
!predictions/C1/*.npz
!predictions/C2/*.npz
!predictions/C3/*.npz
!predictions/C4/*.npz
!predictions/C5/*.npz
*.pkl
*.rds
*.mtx
*.mtx.gz
*.zip
*.tar
*.tar.gz
*.parquet

